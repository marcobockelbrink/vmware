# =============================================================================
# systemd-Unit für die VMware Kapazitätsplanung
# =============================================================================
# Installation:
#   sudo useradd --system --home /opt/kapa --shell /usr/sbin/nologin kapa
#   sudo mkdir -p /opt/kapa && sudo cp aria_kapa.py /opt/kapa/
#   # Laufzeitdaten liegen BEWUSST außerhalb von /opt/kapa unter /var/lib/kapa,
#   # damit eine CI/CD-Pipeline (die /opt/kapa neu befüllt/bereinigt) die Daten
#   # NICHT löscht — siehe --data-dir im ExecStart:
#   sudo mkdir -p /var/lib/kapa && sudo chown kapa:kapa /var/lib/kapa && sudo chmod 750 /var/lib/kapa
#   sudo mkdir -p /etc/kapa
#   sudo cp config/kapa.env.example /etc/kapa/kapa.env   # und Werte eintragen!
#   sudo chown root:kapa /etc/kapa/kapa.env && sudo chmod 640 /etc/kapa/kapa.env
#   # Aria-Passwort als eigene Datei (nur root lesbar, systemd reicht sie durch):
#   sudo sh -c 'echo "DAS-ARIA-PASSWORT" > /etc/kapa/aria.pass'
#   sudo chmod 600 /etc/kapa/aria.pass
#   sudo chown kapa:kapa /opt/kapa/aria_kapa.py
#   sudo cp config/kapa-dashboard.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now kapa-dashboard
# Logs: journalctl -u kapa-dashboard -f
# =============================================================================

[Unit]
Description=VMware Kapazitätsplanung (Aria Operations Dashboard)
Documentation=https://github.com/marcobockelbrink/vmware
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=kapa
Group=kapa
WorkingDirectory=/opt/kapa

# Umgebung (ARIA_URL, ARIA_USER, SMTP_*, ...) — Mode 640 unter /etc/kapa/kapa.env
EnvironmentFile=/etc/kapa/kapa.env

# Aria-Passwort als Datei: systemd kopiert /etc/kapa/aria.pass (root, 600)
# beim Start in ein privates Credentials-Verzeichnis des Dienstes.
# Taucht damit weder in ps aux noch in systemctl show auf.
LoadCredential=aria-password:/etc/kapa/aria.pass

ExecStart=/usr/bin/python3 /opt/kapa/aria_kapa.py --serve \
    --bind 127.0.0.1 --port 8080 \
    --data-dir /var/lib/kapa \
    --exclude-tag ${EXCLUDE_TAG} \
    --url ${ARIA_URL} --user ${ARIA_USER} --auth-source ${ARIA_AUTH_SOURCE} \
    --password-file ${CREDENTIALS_DIRECTORY}/aria-password \
    --ad-url ${AD_URL} --ad-domain ${AD_DOMAIN} --admin-user ${ADMIN_USER} \
    --ad-bind-dn ${AD_BIND_DN} --ad-base-dn ${AD_BASE_DN} \
    --ad-bind-password-file ${AD_BIND_PASSWORD_FILE} \
    --ad-mail-attribute ${AD_MAIL_ATTRIBUTE} \
    --smtp-server ${SMTP_SERVER} --smtp-from ${SMTP_FROM} --smtp-to ${SMTP_TO} \
    --backup-target ${BACKUP_TARGET} --backup-port ${BACKUP_PORT} --backup-key ${BACKUP_KEY} \
    $KAPA_EXTRA_ARGS

Restart=on-failure
RestartSec=10

# Härtung: nur /var/lib/kapa (die Laufzeitdaten) ist beschreibbar, sonst read-only
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/kapa
ProtectKernelTunables=true
ProtectControlGroups=true
RestrictSUIDSGID=true

[Install]
WantedBy=multi-user.target
