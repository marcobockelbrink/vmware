# =============================================================================
# Umgebung für kapa-dashboard.service — Vorlage
# =============================================================================
# Nach /etc/kapa/kapa.env kopieren und Werte eintragen. Wichtig:
#   sudo chown root:kapa /etc/kapa/kapa.env
#   sudo chmod 640 /etc/kapa/kapa.env
# Empfehlung: für ARIA_USER ein eigenes Service-Konto in Aria Operations mit
# NUR-LESE-Rolle anlegen — das Skript liest ausschließlich Daten.
# =============================================================================

# Aria Operations (Pflicht)
ARIA_URL=https://aria-ops.firma.de
ARIA_USER=svc-kapa-readonly
ARIA_PASSWORD=hier-das-passwort
ARIA_AUTH_SOURCE=local

# Active-Directory-Anmeldung fürs Dashboard (leer lassen = kein Login)
AD_URL=ldaps://dc01.firma.local
AD_DOMAIN=firma.local
ADMIN_USER=vorname.nachname@firma.local

# Mail-Reports (leer lassen = keine Mails)
SMTP_SERVER=mail.firma.local:25
SMTP_FROM=kapa-dashboard@firma.local
SMTP_TO=vmware-team@firma.local
#SMTP_PASSWORD=nur-falls-der-mailserver-anmeldung-verlangt

# SFTP-Backup: Passwort nur nötig, wenn kein SSH-Key verwendet wird
#BACKUP_PASSWORD=nur-mit-installiertem-sshpass

# Zusätzliche Argumente, z. B. Self-Signed-Zertifikate, CPU-Faktor oder
# eine INI-Datei mit allen weiteren Optionen (siehe kapa.ini.example):
#KAPA_EXTRA_ARGS=--insecure --ad-insecure --config /etc/kapa/kapa.ini
KAPA_EXTRA_ARGS=
