# =============================================================================
# Umgebung für kapa-dashboard.service — Vorlage
# =============================================================================
# Nach /etc/kapa/kapa.env kopieren und Werte eintragen. Wichtig:
#   sudo chown root:kapa /etc/kapa/kapa.env
#   sudo chmod 640 /etc/kapa/kapa.env
# Empfehlung: für ARIA_USER ein eigenes Service-Konto in Aria Operations mit
# NUR-LESE-Rolle anlegen — das Skript liest ausschließlich Daten.
# =============================================================================

# Aria Operations (Pflicht)
# Das Passwort liegt NICHT hier, sondern in /etc/kapa/aria.pass (root, 600)
# und wird per systemd LoadCredential an den Dienst übergeben.
# (Alternative ohne systemd: ARIA_PASSWORD hier setzen.)
ARIA_URL=https://aria-ops.firma.de
ARIA_USER=svc-kapa-readonly
ARIA_AUTH_SOURCE=local
#ARIA_PASSWORD=nur-falls-ohne-LoadCredential

# Systeme mit diesem vROps-Tag aus der Auswertung ausschließen (leer = aus)
EXCLUDE_TAG=Kapa_Filter:Ja

# Active-Directory-Anmeldung fürs Dashboard (leer lassen = kein Login)
AD_URL=ldaps://dc01.firma.local
AD_DOMAIN=firma.local
ADMIN_USER=vorname.nachname@firma.local

# AD-Gruppenberechtigung (optional): Service-Konto für die memberOf-Suche.
# Leer lassen = nur direkt zugewiesene Benutzer werden berechtigt.
AD_BIND_DN=
AD_BASE_DN=
# Passwort des Service-Kontos – zwei Varianten (leer lassen = keins):
#   a) direkt hier:  AD_BIND_PASSWORD=...
#   b) als Datei (empfohlen), muss vom Benutzer 'kapa' lesbar sein:
#        sudo sh -c 'echo "PASSWORT" > /etc/kapa/ad_bind.pass'
#        sudo chown root:kapa /etc/kapa/ad_bind.pass && sudo chmod 640 /etc/kapa/ad_bind.pass
#      dann hier den Pfad setzen:
#AD_BIND_PASSWORD=passwort-des-service-kontos
AD_BIND_PASSWORD_FILE=

# Mail-Reports (leer lassen = keine Mails)
SMTP_SERVER=mail.firma.local:25
SMTP_FROM=kapa-dashboard@firma.local
SMTP_TO=vmware-team@firma.local
#SMTP_PASSWORD=nur-falls-der-mailserver-anmeldung-verlangt

# SFTP-Backup (leer lassen = kein Backup)
#   Ziel = user@backupsrv:/pfad/zum/backup   ·   Port abweichend von 22 optional
BACKUP_TARGET=
BACKUP_PORT=22
# Authentifizierung: SSH-Key (empfohlen) ODER Passwort (braucht sshpass)
# WICHTIG: Der Key darf NICHT im Home-Verzeichnis liegen – die systemd-Härtung
# (ProtectHome=true) blendet Home-Verzeichnisse für den Dienst aus. Ablage unter
# /etc/kapa/, und er muss dem Dienst-Benutzer gehören (ssh verweigert sonst):
#   sudo cp ~/.ssh/id_ed25519 /etc/kapa/backup_id_ed25519
#   sudo chown kapa:kapa /etc/kapa/backup_id_ed25519
#   sudo chmod 600 /etc/kapa/backup_id_ed25519
BACKUP_KEY=/etc/kapa/backup_id_ed25519
#BACKUP_PASSWORD=nur-mit-installiertem-sshpass

# Zusätzliche Argumente, z. B. Self-Signed-Zertifikate, CPU-Faktor oder
# eine INI-Datei mit allen weiteren Optionen (siehe kapa.ini.example):
#KAPA_EXTRA_ARGS=--insecure --ad-insecure --config /etc/kapa/kapa.ini
KAPA_EXTRA_ARGS=
