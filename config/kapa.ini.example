# =============================================================================
# Konfigurationsdatei für aria_kapa.py — Vorlage
# =============================================================================
# Verwendung:  python3 aria_kapa.py --config /etc/kapa/kapa.ini --serve
# Schlüssel entsprechen den Kommandozeilen-Optionen (mit - oder _).
#
# RANGFOLGE (wichtig!):  Kommandozeile  >  diese INI  >  eingebauter Standard
#
# ACHTUNG beim Betrieb mit systemd: Die Unit baut aus kapa.env
# Kommandozeilen-Argumente (z. B. --url ${ARIA_URL}). Diese schlagen die INI —
# und zwar AUCH, wenn die Variable in kapa.env leer ist! Ein leeres Argument
# überschreibt den INI-Wert mit "leer".
#   => Eine Option entweder in kapa.env ODER hier pflegen, nicht in beiden.
#   => In der INI gehören die Optionen, die die Unit NICHT übergibt, z. B.
#      cpu-factor, failover-hosts, res-ttl-days, contact-info, tag-property,
#      backup-interval, backup-keep-days.
#      Eingebunden wird sie über:  KAPA_EXTRA_ARGS=--config /etc/kapa/kapa.ini
#
# Enthält die Datei Passwörter: chmod 600 nicht vergessen!
# (Passwörter alternativ per Umgebung: ARIA_PASSWORD, SMTP_PASSWORD,
#  BACKUP_PASSWORD, AD_BIND_PASSWORD — diese greifen als LETZTE Rückfallebene:
#  Parameter > Passwort-Datei > Umgebungsvariable; siehe kapa.env.example)
# =============================================================================

[kapa]
# --- Aria Operations --------------------------------------------------------
url = https://aria-ops.firma.de
user = svc-kapa-readonly
#password = besser-per-ARIA_PASSWORD-umgebungsvariable
auth-source = local
#insecure = true                 ; Self-Signed-Zertifikat akzeptieren

# --- Berechnung ---------------------------------------------------------------
cpu-factor = 6
failover-hosts = 1

# --- Webserver ----------------------------------------------------------------
serve = true
bind = 127.0.0.1
port = 8080
refresh-interval = 1800

# --- Kontakt / Impressum ------------------------------------------------------
# Wird im Footer und auf der Login-Maske angezeigt (Rückfragen).
contact-info = IT-Betrieb Musterfirma · kapa-support@firma.local

# --- Datenablage --------------------------------------------------------------
# Basisordner aller Laufzeitdaten. Bei CI/CD-Deployments AUSSERHALB des
# Deploy-Verzeichnisses wählen, sonst löscht die Pipeline die Daten bei jedem
# Deploy (data/ ist gitignored, also nicht im Artefakt enthalten).
data-dir = /var/lib/kapa

# --- Reservierungen -----------------------------------------------------------
res-ttl-days = 31
#res-file = kapa_reservierungen.json
#cache = kapa_cache.json

# --- Mehrstufiger Genehmigungsprozess -----------------------------------------
# Die Genehmigungs-Teams werden auf der VERWALTUNGSSEITE gepflegt und in
# data/kapa_teams.json gespeichert. Der folgende Wert dient nur zur einmaligen
# Erstbefüllung, falls diese Datei noch nicht existiert (danach hat die
# Verwaltungsseite Vorrang). Team-Namen komma-getrennt, in Prüfreihenfolge.
# Leer/auskommentiert = einstufig (Admin genehmigt direkt).
#approval-teams = Team Netzwerk, Team Security, Team Betrieb

# --- Active-Directory-Anmeldung ------------------------------------------------
ad-url = ldaps://dc01.firma.local
ad-domain = firma.local
admin-user = vorname.nachname@firma.local
#ad-insecure = true
# Session-Cookie ohne Secure-Flag – nur für lokalen HTTP-Test ohne HTTPS-Proxy:
#cookie-insecure = true
#roles-file = data/kapa_rollen.json

# --- Mail-Reports ---------------------------------------------------------------
smtp-server = mail.firma.local:25
smtp-from = kapa-dashboard@firma.local
smtp-to = vmware-team@firma.local
#smtp-user =
#smtp-tls = true

# --- SFTP-Backup ----------------------------------------------------------------
backup-target = backup@backupsrv.firma.local:/backup/kapa
backup-key = /etc/kapa/backup_ed25519
#backup-password = nur-mit-installiertem-sshpass
backup-port = 22
backup-interval = 43200          ; zweimal täglich
backup-keep-days = 30            ; ältere Archive auf dem Ziel löschen
