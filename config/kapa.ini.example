# =============================================================================
# Konfigurationsdatei für aria_kapa.py — die EINZIGE Stelle für alle
# nicht-geheimen Einstellungen.  Vorlage -> /etc/kapa/kapa.ini
# =============================================================================
# Verwendung:  python3 aria_kapa.py --config /etc/kapa/kapa.ini --serve
# Schlüssel = Kommandozeilen-Optionen (mit - oder _).
#
# KONFIGURATIONS-MODELL (bewusst einfach gehalten):
#   * Geheimnisse (Passwörter/Keys)  -> eigene Dateien, hier nur der PFAD
#                                        (password-file, ad-bind-password-file, …)
#   * Alles andere                   -> genau hier in dieser INI
#   * Fachdaten (Rollen, Teams,       -> Admin-UI, gespeichert unter data-dir
#     Mail-Regeln, Selektor, Tokens)
#   => Jede Einstellung hat GENAU EINE Quelle. Keine Doppelpflege in env/INI.
#
# Die systemd-Unit ruft nur noch `--config /etc/kapa/kapa.ini --serve` auf –
# es gibt keine ${VARS} mehr, die INI-Werte überschreiben könnten.
#
# Rechte:  chown root:kapa /etc/kapa/kapa.ini && chmod 640 /etc/kapa/kapa.ini
# (Passwörter stehen NICHT hier, sondern in eigenen 0640-Dateien, siehe unten.)
# =============================================================================

[kapa]
# --- Aria Operations ----------------------------------------------------------
url = https://aria-ops.firma.de
user = svc-kapa-readonly
# Optionaler Anzeigename der Quelle (wie der Sektionsname bei [quelle:NAME]):
# erscheint als Quellen-Badge am Cluster und im vROps-Quickfilter des Selektors.
#source-name = RZ-Nord
# Aria-Passwort NICHT hier, sondern als eigene Datei (root:kapa, 0640):
#   sudo sh -c 'echo "DAS-ARIA-PASSWORT" > /etc/kapa/aria.pass'
#   sudo chown root:kapa /etc/kapa/aria.pass && sudo chmod 640 /etc/kapa/aria.pass
password-file = /etc/kapa/aria.pass
auth-source = local
#insecure = true                 ; Self-Signed-Zertifikat akzeptieren
#aria-proxy = http://proxy.firma.local:3128   ; optionaler Proxy (leer = direkt)

# --- Mehrere vROps-Datenquellen (optional) ------------------------------------
# Statt der einen Quelle oben lassen sich mehrere benannte vROps einbinden: je
# eine [quelle:NAME]-Sektion. Der Name (nach "quelle:") wird im Dashboard als
# Badge am Cluster angezeigt. Jede Quelle mit eigener URL/Benutzer/Passwort-Datei
# und wahlweise mit oder ohne Proxy. VORAUSSETZUNG: Cluster-Namen sind über alle
# Quellen hinweg EINDEUTIG. Sind [quelle:*]-Sektionen vorhanden, werden die
# url/user aus [kapa] ignoriert (die übrigen [kapa]-Werte gelten weiter global).
#
#[quelle:RZ-Nord]
#url = https://aria-nord.firma.de
#user = svc-kapa-readonly
#password-file = /etc/kapa/aria-nord.pass
#auth-source = local
##aria-proxy =                    ; ohne Proxy
#
#[quelle:RZ-Sued]
#url = https://aria-sued.firma.de
#user = svc-kapa-readonly
#password-file = /etc/kapa/aria-sued.pass
#aria-proxy = http://proxy.firma.local:3128   ; mit Proxy
##insecure = true

# --- Berechnung ---------------------------------------------------------------
cpu-factor = 6
failover-hosts = 1
vsan-factor = 0.5                 ; vSAN-Bruttokapazität nur anteilig nutzbar
res-ttl-days = 31
# Tanzu-/vSphere-Namespaces: deren CPU-/RAM-Reservierungen zählen automatisch
# gegen die freie Kapazität (ohne Tanzu passiert nichts). Die CPU-Reservierung
# kommt in MHz aus vROps und wird so in vCPU-Äquivalente umgerechnet:
#tanzu-mhz-per-vcpu = 2500        ; MHz je vCPU (0 = CPU nicht zählen, nur RAM)

# --- Kapa-ID neuer Reservierungen ---------------------------------------------
# Aufbau: <id-prefix><Zufallsteil>. Prefix optional (Buchstaben/Ziffern/-/_),
# id-length = Anzahl Hex-Zeichen des Zufallsteils (4–40). Beispiel:
#   id-prefix = KAPA-  und  id-length = 6   ->   KAPA-004fb0
#id-prefix =
#id-length = 12

# --- Netzwerk / VLAN ----------------------------------------------------------
# Uplink-/Trunk-Portgruppen (Name enthält "uplink" oder VLAN 0-4094) werden
# standardmäßig ausgeblendet. Auf 'true' setzen, um sie einzublenden.
#show-uplink-portgroups = true
# Systeme mit diesem vROps-Tag aus der Auswertung ausschließen (leer = aus):
#exclude-tag = Kapa_Filter:Ja
#tag-property = summary|tag       ; Präfix für die vSphere-Tags des Clusters

# --- Webserver ----------------------------------------------------------------
bind = 127.0.0.1
port = 8080
refresh-interval = 1800

# --- Kontakt / Impressum ------------------------------------------------------
contact-info = IT-Betrieb Musterfirma · kapa-support@firma.local

# --- Datenablage --------------------------------------------------------------
# Basisordner aller Laufzeitdaten. BEWUSST außerhalb des Deploy-Verzeichnisses,
# sonst löscht eine CI/CD-Pipeline die Daten (data/ ist gitignored).
data-dir = /var/lib/kapa

# --- Datenspeicher ------------------------------------------------------------
# json (Standard) = je Sammlung eine editierbare .json-Datei im data-dir.
# sqlite          = eine data/kapa.db (Stdlib, kein Server); lohnt erst bei
#                   sehr vielen (mehrere Tausend) aktiven Reservierungen.
#storage = json

# --- Genehmigungs-Teams (nur Erstbefüllung) -----------------------------------
# Danach werden Teams auf der Verwaltungsseite gepflegt (data/kapa_teams.json).
#approval-teams = Team Netzwerk, Team Security, Team Betrieb

# --- Active-Directory-Anmeldung (leer = kein Login) ---------------------------
ad-url = ldaps://dc01.firma.local
ad-domain = firma.local
admin-user = vorname.nachname@firma.local
#ad-insecure = true
#cookie-insecure = true           ; Cookie ohne Secure – nur für lokalen HTTP-Test
# AD-Gruppenberechtigung + AD-Mailattribut brauchen ein Service-Konto:
#ad-bind-dn = CN=svc-kapa,OU=Service,DC=firma,DC=local
#ad-base-dn = DC=firma,DC=local
#ad-bind-password-file = /etc/kapa/ad_bind.pass     ; eigene Datei (root:kapa 0640)
# Empfänger-Mailadresse des Anforderers aus einem AD-Attribut statt dem UPN:
#ad-mail-attribute = mail

# --- Mail-Versand (leer = keine Mails; Regeln pflegt das Admin-UI) ------------
smtp-server = mail.firma.local:25
smtp-from = kapa-dashboard@firma.local
# smtp-to dient nur noch als Rückfall-Adresse für die Rolle "Admin", falls im
# Admin-UI keine Admin-Verteiler-Adresse gesetzt ist:
#smtp-to = vmware-team@firma.local
#smtp-tls = true
#smtp-user = kapa
#smtp-password-file = /etc/kapa/smtp.pass           ; nur falls der Server Auth verlangt

# --- SFTP-Backup (leer = kein Backup) -----------------------------------------
#backup-target = backup@backupsrv.firma.local:/backup/kapa
#backup-port = 22
# SSH-Key (empfohlen) – NICHT im Home ablegen (systemd ProtectHome), dem Dienst
# gehörend: chown kapa:kapa, chmod 600:
#backup-key = /etc/kapa/backup_id_ed25519
#backup-password-file = /etc/kapa/backup.pass       ; Alternative, braucht sshpass
backup-interval = 43200          ; zweimal täglich
backup-keep-days = 30            ; ältere Archive auf dem Ziel löschen
