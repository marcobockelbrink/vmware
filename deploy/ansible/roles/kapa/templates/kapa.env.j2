# {{ ansible_managed }}
# Wird von der Ansible-Role kapa verwaltet – Änderungen hier werden überschrieben.

# Aria Operations
ARIA_URL={{ kapa_aria_url }}
ARIA_USER={{ kapa_aria_user }}
ARIA_AUTH_SOURCE={{ kapa_aria_auth_source }}
# Passwort liegt in /etc/kapa/aria.pass (per systemd LoadCredential)

# Active-Directory-Anmeldung
AD_URL={{ kapa_ad_url }}
AD_DOMAIN={{ kapa_ad_domain }}
ADMIN_USER={{ kapa_admin_user }}

# Mail-Reports
SMTP_SERVER={{ kapa_smtp_server }}
SMTP_FROM={{ kapa_smtp_from }}
SMTP_TO={{ kapa_smtp_to }}
{% if kapa_smtp_password | length > 0 %}
SMTP_PASSWORD={{ kapa_smtp_password }}
{% endif %}

# Zusätzliche Argumente
KAPA_EXTRA_ARGS={{ kapa_extra_args }}
